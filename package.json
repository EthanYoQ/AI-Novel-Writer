{
  "name": "ai-novel-writer",
  "version": "0.2.2",
  "description": "AI Novel Writer - a local-first production workspace for long-form fiction",
  "author": "AI Novel Writer Maintainers",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=20"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "clean:build": "node scripts/clean-build-output.mjs",
    "typecheck": "tsc --noEmit",
    "check:i18n": "node scripts/check-i18n-coverage.mjs",
    "test": "vitest run",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win --x64",
    "build:win-dir": "pnpm run clean:build && pnpm run typecheck && vite build && electron-builder --win dir --x64 && pnpm run verify:win-package",
    "build:win-zip": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-win-zip.ps1",
    "verify:win-package": "node scripts/verify-win-package.mjs",
    "smoke:win-app": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-win-app.ps1",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lancedb/lancedb": "^0.27.2",
    "@lezer/highlight": "^1.2.3",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@uiw/react-codemirror": "^4.25.9",
    "apache-arrow": "^18.1.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff-match-patch": "^1.0.5",
    "flatbuffers": "^25.9.23",
    "lucide-react": "^1.8.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.9.0",
    "reflect-metadata": "^0.2.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@electron/rebuild": "^4.0.3",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff-match-patch": "^1.0.36",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-storybook": "^10.3.5",
    "playwright": "^1.59.1",
    "postcss": "^8.5.9",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.4"
  },
  "optionalDependencies": {
    "@lancedb/lancedb-win32-x64-msvc": "0.27.2"
  }
}
